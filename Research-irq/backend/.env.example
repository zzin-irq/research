# Backend secrets — never commit a populated .env

NODE_ENV=development
PORT=4000
TRUST_PROXY=0

# CORS allowlist — comma-separated origins
FRONTEND_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgres://research:research@localhost:5432/research_irq

# Auth
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"
JWT_ACCESS_TTL=15m
REFRESH_TTL_DAYS=30
BCRYPT_COST=12

# Mail (Resend in prod, MailHog in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM="IPISH <noreply@example.com>"

# Storage (local in dev, R2 in prod)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=../storage/uploads
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# Observability
LOG_LEVEL=info
SENTRY_DSN=

# Anti-abuse
RECAPTCHA_SECRET=

# Claude API (Anthropic) — used when Claude Code session tokens are exhausted
ANTHROPIC_API_KEY=
