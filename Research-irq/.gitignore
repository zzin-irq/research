# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.vite/
*.tsbuildinfo

# Env files — only .env.example is tracked
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Test artefacts
coverage/
playwright-report/
test-results/
*.snapshot.diff

# Local uploads (dev storage)
storage/uploads/*
!storage/uploads/.gitkeep

# Sentry source maps
.sentryclirc

# Docker volumes (when bind-mounted)
.docker/

# Lockfile noise we don't want
yarn-error.log
